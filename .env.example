# ─────────────────────────────────────────────────────────────────────────────
# Fuse — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
PROJECT_NAME=Fuse
API_V1_STR=/api/v1
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# ── Security (required) ───────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
SECRET_KEY=your-secret-key-here
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# ── Database (PostgreSQL + pgvector) ─────────────────────────────────────────
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fuse

# ── Cache / Queue (Redis) ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Email / SMTP (optional — invites are logged if not set) ──────────────────
# Works with SendGrid, Gmail, Mailgun, SES, Postmark, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com
SMTP_FROM_NAME=Fuse
SMTP_TLS=true

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=/api/v1

# ── OAuth Integrations (optional — only add what you use) ────────────────────

# Slack — https://api.slack.com/apps
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# GitHub — https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Notion (public integration) — https://www.notion.so/my-integrations
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# Discord — https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Linear
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=

# Google (Gmail OAuth) — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
